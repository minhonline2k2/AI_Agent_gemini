# ============================================
# AI Incident Management Platform
# File cau hinh - COPY thanh .env va sua lai
# ============================================

# --- App ---
APP_NAME=AI Incident Platform
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=thay-bang-chuoi-ngau-nhien-32-ky-tu-tro-len

# --- Database ---
POSTGRES_USER=aiops
POSTGRES_PASSWORD=thay-bang-mat-khau-manh
POSTGRES_DB=ai_incident_db
DATABASE_URL=postgresql+asyncpg://aiops:thay-bang-mat-khau-manh@postgres:5432/ai_incident_db
DATABASE_URL_SYNC=postgresql://aiops:thay-bang-mat-khau-manh@postgres:5432/ai_incident_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=thay-bang-jwt-secret-ngau-nhien
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Gemini AI ---
GEMINI_API_KEY=thay-bang-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_CONCURRENT=10
GEMINI_TIMEOUT=60

# --- Agent Auth ---
AGENT_SECRET=thay-bang-agent-secret-ngau-nhien

# --- Ingestion ---
INGEST_TOKEN=thay-bang-ingest-token-ngau-nhien
INGEST_RATE_LIMIT=100

# --- Public URL ---
PUBLIC_URL=https://app.example.com
